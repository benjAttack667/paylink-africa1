APP_DOMAIN=pay.example.com
CADDY_EMAIL=ops@example.com

POSTGRES_DB=paylink_africa
POSTGRES_USER=paylink
POSTGRES_PASSWORD=change-this-long-postgres-password

NODE_ENV=production
SERVICE_NAME=payment-links-api
PORT=4000
TRUST_PROXY_HOPS=1
DATABASE_URL=postgresql://paylink:change-this-long-postgres-password@postgres:5432/paylink_africa?schema=public
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=12h
JWT_COOKIE_NAME=paylink_access
JWT_COOKIE_MAX_AGE=12h
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=
CSRF_HEADER_NAME=x-csrf-token
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_LOGIN_RATE_LIMIT_MAX=8
AUTH_REGISTER_RATE_LIMIT_MAX=4
PAYMENT_RATE_LIMIT_WINDOW_MINUTES=15
PAYMENT_RATE_LIMIT_MAX=20
PAYMENT_GATEWAY=FLUTTERWAVE
PAYMENT_CURRENCY=NGN
API_PUBLIC_URL=https://pay.example.com
FLUTTERWAVE_API_BASE_URL=https://api.flutterwave.com
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST_xxx
FLUTTERWAVE_WEBHOOK_HASH=replace-with-your-webhook-hash
FLUTTERWAVE_CHECKOUT_SESSION_DURATION_MINUTES=30
FLUTTERWAVE_MAX_RETRY_ATTEMPTS=5
CLIENT_URL=https://pay.example.com
ALLOWED_ORIGINS=https://pay.example.com
LOG_FORMAT=combined
LOG_LEVEL=info

NEXT_PUBLIC_API_BASE_URL=https://pay.example.com/api
