NODE_ENV=development
SERVICE_NAME=payment-links-api
PORT=4000
TRUST_PROXY_HOPS=1
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/paylink_africa?schema=public"
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="12h"
JWT_COOKIE_NAME="paylink_access"
JWT_COOKIE_MAX_AGE="12h"
COOKIE_SECURE="false"
COOKIE_SAME_SITE="lax"
COOKIE_DOMAIN=""
CSRF_HEADER_NAME="x-csrf-token"
AUTH_RATE_LIMIT_WINDOW_MINUTES="15"
AUTH_LOGIN_RATE_LIMIT_MAX="8"
AUTH_REGISTER_RATE_LIMIT_MAX="4"
PAYMENT_RATE_LIMIT_WINDOW_MINUTES="15"
PAYMENT_RATE_LIMIT_MAX="20"
PAYMENT_GATEWAY="MOCK"
ALLOW_MOCK_PAYMENTS_IN_PRODUCTION="false"
PAYMENT_CURRENCY="NGN"
API_PUBLIC_URL="http://localhost:4000"
FLUTTERWAVE_API_BASE_URL="https://api.flutterwave.com"
FLUTTERWAVE_SECRET_KEY=""
FLUTTERWAVE_WEBHOOK_HASH="change-me"
FLUTTERWAVE_CHECKOUT_SESSION_DURATION_MINUTES="30"
FLUTTERWAVE_MAX_RETRY_ATTEMPTS="5"
CLIENT_URL="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000"
LOG_FORMAT="dev"
LOG_LEVEL="info"
